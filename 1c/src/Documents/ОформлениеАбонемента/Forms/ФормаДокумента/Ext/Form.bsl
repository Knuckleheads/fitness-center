#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Дата      = ТекущаяДата();
		Объект.ДатаНачала = НачалоДня(ТекущаяДата());
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
КонецПроцедуры

&НаКлиенте
Процедура ВидАбонементаПриИзменении(Элемент)
	ЗаполнитьПоВидуАбонементаНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ДатаНачалаПриИзменении(Элемент)
	ПересчитатьДатуОкончанияНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоВидуАбонементаНаСервере()
	Если Объект.ВидАбонемента.Пустая() Тогда
		Возврат;
	КонецЕсли;
	ВидАб = Объект.ВидАбонемента.ПолучитьОбъект();
	Объект.КоличествоПосещений = ВидАб.КоличествоПосещений;
	Объект.Сумма               = ВидАб.Цена;
	ДнейДействия               = ВидАб.СрокДействияВДнях - 1;
	Объект.ДатаОкончания       = КонецДня(Объект.ДатаНачала + ДнейДействия * 86400);
КонецПроцедуры

&НаСервере
Процедура ПересчитатьДатуОкончанияНаСервере()
	Если Объект.ВидАбонемента.Пустая() Тогда
		Возврат;
	КонецЕсли;
	ВидАб          = Объект.ВидАбонемента.ПолучитьОбъект();
	ДнейДействия   = ВидАб.СрокДействияВДнях - 1;
	Объект.ДатаОкончания = КонецДня(Объект.ДатаНачала + ДнейДействия * 86400);
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	// Проверка обязательных полей
	Если Объект.Клиент.Пустая() Тогда
		Сообщить("Необходимо указать клиента!");
		Отказ = Истина;
	ИначеЕсли Объект.ВидАбонемента.Пустая() Тогда
		Сообщить("Необходимо указать вид абонемента!");
		Отказ = Истина;
	ИначеЕсли Объект.Сумма <= 0 Тогда
		Сообщить("Сумма должна быть больше нуля!");
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Оповестить("ОбновлениеДокумента_ОформлениеАбонемента");
КонецПроцедуры

#КонецОбласти
