#Область ОбработчикиСобытий

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	Движения.ПосещенияКлиентов.Записывать = Истина;

	ДвижениеПосещения = Движения.ПосещенияКлиентов.Добавить();
	ДвижениеПосещения.Клиент = Клиент;
	ДвижениеПосещения.Занятие = Занятие;
	ДвижениеПосещения.АбонементКлиента = АбонементКлиента;
	ДвижениеПосещения.ДокументПосещения = Ссылка;

	Если ЗначениеЗаполнено(АбонементКлиента) Тогда
		Если ОстатокПосещенийАбонемента(АбонементКлиента) < 1 Тогда
			Отказ = Истина;
			Сообщить("Недостаточно посещений по абонементу клиента.");
			Возврат;
		КонецЕсли;

		Движения.ОстаткиАбонементов.Записывать = Истина;

		ДвижениеОстатка = Движения.ОстаткиАбонементов.Добавить();
		ДвижениеОстатка.ВидДвижения = ВидДвиженияНакопления.Расход;
		ДвижениеОстатка.Период = Дата;
		ДвижениеОстатка.АбонементКлиента = АбонементКлиента;
		ДвижениеОстатка.КоличествоПосещений = 1;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОстатокПосещенийАбонемента(АбонементКлиента)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	| ЕСТЬNULL(Остатки.КоличествоПосещенийОстаток, 0) КАК Остаток
	|ИЗ
	| РегистрНакопления.ОстаткиАбонементов.Остатки(&Момент, АбонементКлиента = &АбонементКлиента) КАК Остатки";
	Запрос.УстановитьПараметр("Момент", Дата);
	Запрос.УстановитьПараметр("АбонементКлиента", АбонементКлиента);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Остаток;
	КонецЕсли;

	Возврат 0;

КонецФункции

#КонецОбласти