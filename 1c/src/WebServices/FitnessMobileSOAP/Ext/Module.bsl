#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СтрокаJSON(Данные)

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	Возврат ЗаписьJSON.Закрыть();

КонецФункции

Функция СписокКлиентов()

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	| Клиенты.Ссылка КАК Ссылка,
	| Клиенты.Наименование КАК Наименование
	|ИЗ
	| Справочник.Клиенты КАК Клиенты
	|ГДЕ
	| НЕ Клиенты.ПометкаУдаления";

	Возврат МассивИзВыборки(Запрос.Выполнить().Выбрать());

КонецФункции

Функция СписокЗанятий()

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	| Занятия.Ссылка КАК Ссылка,
	| Занятия.Наименование КАК Наименование
	|ИЗ
	| Справочник.Занятия КАК Занятия
	|ГДЕ
	| НЕ Занятия.ПометкаУдаления";

	Возврат МассивИзВыборки(Запрос.Выполнить().Выбрать());

КонецФункции

Функция МассивИзВыборки(Выборка)

	Результат = Новый Массив;
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Новый Структура("ref, name", Строка(Выборка.Ссылка.УникальныйИдентификатор()),
			Выборка.Наименование));
	КонецЦикла;

	Возврат Результат;

КонецФункции

#КонецОбласти
