#Область ПрограммныйИнтерфейс

Функция Health()

	Возврат СтрокаJSON(Новый Структура("status, service", "ok", "fitness-soap"));

КонецФункции

Функция GetClientsJSON()

	Возврат СтрокаJSON(Новый Структура("items", СписокКлиентов()));

КонецФункции

Функция GetClassesJSON()

	Возврат СтрокаJSON(Новый Структура("items", СписокЗанятий()));

