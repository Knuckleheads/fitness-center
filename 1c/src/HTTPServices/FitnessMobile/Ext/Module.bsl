Функция MembershipsPOSTЗапрос(Запрос)

	Попытка
		Данные = ДанныеJSONИзЗапроса(Запрос);
		Клиент = СсылкаСправочникаКлиенты(ОбязательноеПоле(Данные, "clientRef"));
		ВидАбонемента = СсылкаСправочникаВидыАбонементов(ОбязательноеПоле(Данные, "membershipTypeRef"));

		КоличествоПосещений = ЧислоИлиЗначениеПоУмолчанию(ПолеИлиПустаяСтрока(Данные, "visitsCount"), ВидАбонемента.КоличествоПосещений);
		Сумма = ЧислоИлиЗначениеПоУмолчанию(ПолеИлиПустаяСтрока(Данные, "amount"), ВидАбонемента.Цена);
		ДатаНачала = ТекущаяДата();
		ДатаОкончания = ДатаНачала + ВидАбонемента.СрокДействияВДнях * 24 * 60 * 60;

		АбонементОбъект = Справочники.АбонементыКлиентов.СоздатьЭлемент();
		АбонементОбъект.Наименование = Строка(Клиент) + " - " + Строка(ВидАбонемента);
		АбонементОбъект.Клиент = Клиент;
		АбонементОбъект.ВидАбонемента = ВидАбонемента;
		АбонементОбъект.ДатаНачала = ДатаНачала;
		АбонементОбъект.ДатаОкончания = ДатаОкончания;
		АбонементОбъект.ОстатокПосещений = КоличествоПосещений;
		АбонементОбъект.Активен = Истина;
		АбонементОбъект.Записать();

		Документ = Документы.ОформлениеАбонемента.СоздатьДокумент();
		Документ.Дата = ТекущаяДата();
		Документ.Клиент = Клиент;
		Документ.ВидАбонемента = ВидАбонемента;
		Документ.АбонементКлиента = АбонементОбъект.Ссылка;
		Документ.ДатаНачала = ДатаНачала;
		Документ.ДатаОкончания = ДатаОкончания;
		Документ.КоличествоПосещений = КоличествоПосещений;
		Документ.Сумма = Сумма;
		Документ.Комментарий = ПолеИлиПустаяСтрока(Данные, "comment");
		Документ.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Возврат JSONОтветОшибки(400, ОписаниеОшибки());
	КонецПопытки;

	Возврат JSONОтвет(201, Новый Структура("membershipRef, documentRef, documentNumber", Строка(АбонементОбъект.Ссылка.УникальныйИдентификатор()), Строка(Документ.Ссылка.УникальныйИдентификатор()), Документ.Номер));

КонецФункции

Функция BookingsPOSTЗапрос(Запрос)

	Попытка
		Данные = ДанныеJSONИзЗапроса(Запрос);
		Документ = Документы.ЗаписьНаЗанятие.СоздатьДокумент();
		Документ.Дата = ТекущаяДата();
		Документ.Клиент = СсылкаСправочникаКлиенты(ОбязательноеПоле(Данные, "clientRef"));
		Документ.Занятие = СсылкаСправочникаЗанятия(ОбязательноеПоле(Данные, "classRef"));
		Документ.АбонементКлиента = СсылкаСправочникаАбонементыКлиентов(ПолеИлиПустаяСтрока(Данные, "membershipRef"));
		Документ.Отменена = Ложь;
		Документ.Комментарий = ПолеИлиПустаяСтрока(Данные, "comment");
		Документ.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Возврат JSONОтветОшибки(400, ОписаниеОшибки());
	КонецПопытки;

	Возврат JSONОтвет(201, ОтветДокумента(Документ.Ссылка));

КонецФункции

