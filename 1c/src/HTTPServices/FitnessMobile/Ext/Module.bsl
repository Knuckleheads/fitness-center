Функция ClientsPOSTЗапрос(Запрос)

	Попытка
		Данные = ДанныеJSONИзЗапроса(Запрос);
		Имя = ОбязательноеПоле(Данные, "name");

		КлиентОбъект = Справочники.Клиенты.СоздатьЭлемент();
		КлиентОбъект.Наименование = Имя;
		КлиентОбъект.Телефон = ПолеИлиПустаяСтрока(Данные, "phone");
		КлиентОбъект.ЭлектроннаяПочта = ПолеИлиПустаяСтрока(Данные, "email");
		КлиентОбъект.Активен = Истина;
		КлиентОбъект.Записать();
	Исключение
		Возврат JSONОтветОшибки(400, ОписаниеОшибки());
	КонецПопытки;

	Возврат JSONОтвет(201, Новый Структура("ref, name, phone",
		Строка(КлиентОбъект.Ссылка.УникальныйИдентификатор()),
		КлиентОбъект.Наименование,
		КлиентОбъект.Телефон));

