Функция ЧислоИлиЗначениеПоУмолчанию(Значение, ЗначениеПоУмолчанию)

	Если ПустаяСтрока(Значение) Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Возврат Число(Значение);

КонецФункции

Функция СписокВидовАбонементов()

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	| ВидыАбонементов.Ссылка КАК Ссылка,
	| ВидыАбонементов.Наименование КАК Наименование,
	| ВидыАбонементов.КоличествоПосещений КАК КоличествоПосещений,
	| ВидыАбонементов.СрокДействияВДнях КАК СрокДействияВДнях,
	| ВидыАбонементов.Цена КАК Цена
	|ИЗ
	| Справочник.ВидыАбонементов КАК ВидыАбонементов
	|ГДЕ
	| НЕ ВидыАбонементов.ПометкаУдаления";

	Результат = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Новый Структура("ref, name, visitsCount, validityDays, price", Строка(Выборка.Ссылка.УникальныйИдентификатор()), Выборка.Наименование, Выборка.КоличествоПосещений, Выборка.СрокДействияВДнях, Выборка.Цена));
	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция СписокАбонементовКлиентов()

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	| АбонементыКлиентов.Ссылка КАК Ссылка,
	| АбонементыКлиентов.Наименование КАК Наименование,
	| АбонементыКлиентов.Клиент КАК Клиент,
	| АбонементыКлиентов.ВидАбонемента КАК ВидАбонемента,
	| АбонементыКлиентов.ДатаНачала КАК ДатаНачала,
	| АбонементыКлиентов.ДатаОкончания КАК ДатаОкончания,
	| АбонементыКлиентов.Активен КАК Активен
	|ИЗ
	| Справочник.АбонементыКлиентов КАК АбонементыКлиентов
	|ГДЕ
	| НЕ АбонементыКлиентов.ПометкаУдаления";

	Результат = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Новый Структура("ref, name, clientRef, membershipTypeRef, dateStart, dateEnd, active", Строка(Выборка.Ссылка.УникальныйИдентификатор()), Выборка.Наименование, Строка(Выборка.Клиент.УникальныйИдентификатор()), Строка(Выборка.ВидАбонемента.УникальныйИдентификатор()), Выборка.ДатаНачала, Выборка.ДатаОкончания, Выборка.Активен));
	КонецЦикла;

	Возврат Результат;

КонецФункции

