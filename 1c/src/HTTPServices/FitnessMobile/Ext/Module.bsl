Функция СписокКлиентов(Телефон = "")

	Запрос = Новый Запрос;
	Если ПустаяСтрока(Телефон) Тогда
		Запрос.Текст =
		"ВЫБРАТЬ
		| Клиенты.Ссылка КАК Ссылка,
		| Клиенты.Наименование КАК Наименование,
		| Клиенты.Телефон КАК Телефон,
		| Клиенты.ЭлектроннаяПочта КАК ЭлектроннаяПочта,
		| Клиенты.Активен КАК Активен
		|ИЗ
		| Справочник.Клиенты КАК Клиенты
		|ГДЕ
		| НЕ Клиенты.ПометкаУдаления";
	Иначе
		Запрос.Текст =
		"ВЫБРАТЬ
		| Клиенты.Ссылка КАК Ссылка,
		| Клиенты.Наименование КАК Наименование,
		| Клиенты.Телефон КАК Телефон,
		| Клиенты.ЭлектроннаяПочта КАК ЭлектроннаяПочта,
		| Клиенты.Активен КАК Активен
		|ИЗ
		| Справочник.Клиенты КАК Клиенты
		|ГДЕ
		| НЕ Клиенты.ПометкаУдаления
		| И Клиенты.Телефон = &Телефон";
		Запрос.УстановитьПараметр("Телефон", Телефон);
	КонецЕсли;

	Результат = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Новый Структура("ref, name, phone, email, active",
			Строка(Выборка.Ссылка.УникальныйИдентификатор()),
			Выборка.Наименование,
			Выборка.Телефон,
			Выборка.ЭлектроннаяПочта,
			Выборка.Активен));
	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция СписокТренеров()

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	| Тренеры.Ссылка КАК Ссылка,
	| Тренеры.Наименование КАК Наименование,
	| Тренеры.Телефон КАК Телефон,
	| Тренеры.Специализация КАК Специализация,
	| Тренеры.Активен КАК Активен
	|ИЗ
	| Справочник.Тренеры КАК Тренеры
	|ГДЕ
	| НЕ Тренеры.ПометкаУдаления";

	Результат = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Новый Структура("ref, name, phone, spec, active",
			Строка(Выборка.Ссылка.УникальныйИдентификатор()),
			Выборка.Наименование,
			Выборка.Телефон,
			Выборка.Специализация,
			Выборка.Активен));
	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция СписокВидовАбонементов()

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	| ВидыАбонементов.Ссылка КАК Ссылка,
	| ВидыАбонементов.Наименование КАК Наименование,
