#Область СлужебныеПроцедурыИФункции

Функция JSONОтвет(КодСостояния, Данные)

	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=UTF-8");
	Ответ.УстановитьТелоИзСтроки(СтрокаJSON(Данные), КодировкаТекста.UTF8);
	Возврат Ответ;

КонецФункции

Функция JSONОтветОшибки(КодСостояния, ТекстОшибки)

	Возврат JSONОтвет(КодСостояния, Новый Структура("error", ТекстОшибки));

КонецФункции

Функция СтрокаJSON(Данные)

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	Возврат ЗаписьJSON.Закрыть();

КонецФункции

Функция СтрокаODataMetadata()

	Возврат "<?xml version=""1.0"" encoding=""UTF-8""?>"
		+ "<edmx:Edmx Version=""4.0"" xmlns:edmx=""http://docs.oasis-open.org/odata/ns/edmx"">"
		+ "<edmx:DataServices>"
		+ "<Schema Namespace=""FitnessMobile"" xmlns=""http://docs.oasis-open.org/odata/ns/edm"">"
		+ "<EntityType Name=""Client"">"
		+ "<Key><PropertyRef Name=""ref""/></Key>"
		+ "<Property Name=""ref"" Type=""Edm.String"" Nullable=""false""/>"
		+ "<Property Name=""name"" Type=""Edm.String""/>"
		+ "</EntityType>"
		+ "<EntityType Name=""Class"">"
		+ "<Key><PropertyRef Name=""ref""/></Key>"
		+ "<Property Name=""ref"" Type=""Edm.String"" Nullable=""false""/>"
		+ "<Property Name=""name"" Type=""Edm.String""/>"
		+ "</EntityType>"
		+ "<EntityContainer Name=""Container"">"
		+ "<EntitySet Name=""clients"" EntityType=""FitnessMobile.Client""/>"
		+ "<EntitySet Name=""classes"" EntityType=""FitnessMobile.Class""/>"
		+ "</EntityContainer>"
		+ "</Schema>"
		+ "</edmx:DataServices>"
		+ "</edmx:Edmx>";

КонецФункции

Функция ДанныеJSONИзЗапроса(Запрос)

	Тело = Запрос.ПолучитьТелоКакСтроку();
	Если ПустаяСтрока(Тело) Тогда
		ВызватьИсключение "Тело запроса пустое";
	КонецЕсли;

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Тело);
	Данные = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();

	Возврат Данные;

КонецФункции

Функция ОбязательноеПоле(Данные, ИмяПоля)

	ЗначениеПоля = Неопределено;
	Если Не Данные.Свойство(ИмяПоля, ЗначениеПоля) Или ПустаяСтрока(ЗначениеПоля) Тогда
		ВызватьИсключение "Не заполнено поле " + ИмяПоля;
	КонецЕсли;

	Возврат ЗначениеПоля;

КонецФункции

Функция ПолеИлиПустаяСтрока(Данные, ИмяПоля)

	ЗначениеПоля = "";
	Данные.Свойство(ИмяПоля, ЗначениеПоля);
	Возврат ЗначениеПоля;

КонецФункции

